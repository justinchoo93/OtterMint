# Plaid (Sandbox)
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox
# Public https URL Plaid returns the user to after OAuth bank login.
# Must be https with NO query string, and registered in the Plaid dashboard
# (a deploy-time step). Leave unset locally; sandbox linking works without it.
PLAID_REDIRECT_URI=https://your-app.example.com/oauth
# Public https URL of POST /api/plaid/webhook; also registered in the Plaid
# dashboard (deploy-time step). Leave unset locally.
PLAID_WEBHOOK_URL=https://your-app.example.com/api/plaid/webhook

# Supabase Postgres
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Encryption key for Plaid access tokens (32 bytes hex = 64 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_string

# Migration (only needed for initial migration from single-user)
# MIGRATION_EMAIL=you@example.com
# MIGRATION_PASSWORD=your_password
# MIGRATION_NAME=Your Name

# Upstash Redis (rate limiting backend).
# Provision a database at https://upstash.com and paste its REST URL/token.
# DEPLOY-TIME STEP: leave these blank locally and in CI — when they are
# unset the app falls back to an in-memory rate limiter, so dev, CI, and
# tests work without Redis (the in-memory limiter is not correct across
# multiple server instances, which is why production sets these).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Error tracking (Sentry). DEPLOY-TIME STEP: leave these blank locally and in
# CI. Without a DSN the Sentry SDK no-ops and transmits nothing, so dev, tests,
# and the build all work unset; in development Spotlight still shows captured
# events in the dev overlay. Provision real values at deploy time.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Source-map upload at build/deploy time only (optional locally):
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
