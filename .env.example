# Plaid (Sandbox)
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox

# Neon Postgres
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Encryption key for Plaid access tokens (32 bytes hex = 64 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_char_hex_string

# Migration (only needed for initial migration from single-user)
# MIGRATION_EMAIL=you@example.com
# MIGRATION_PASSWORD=your_password
# MIGRATION_NAME=Your Name
